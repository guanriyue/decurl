{
  "name": "@guanriyue/decurl",
  "version": "0.0.2",
  "description": "React Router hooks and runtime helpers for typed Decurl URL Search Params state.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./provided": {
      "types": "./src/provided.tsx",
      "import": "./src/provided.tsx"
    },
    "./codec": {
      "types": "./src/codec/index.ts",
      "import": "./src/codec/index.ts"
    },
    "./decode": {
      "types": "./src/decode/index.ts",
      "import": "./src/decode/index.ts"
    },
    "./pagination": {
      "types": "./src/pagination/index.ts",
      "import": "./src/pagination/index.ts"
    },
    "./routeSpec": {
      "types": "./src/routeSpec/index.ts",
      "import": "./src/routeSpec/index.ts"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --pool=threads --maxWorkers=1 --no-file-parallelism",
    "lint": "biome check ."
  },
  "keywords": [
    "decurl",
    "react",
    "react-router",
    "url",
    "urlsearchparams",
    "search-params",
    "hooks",
    "typescript"
  ],
  "author": {
    "name": "guanriyue",
    "url": "https://github.com/guanriyue"
  },
  "license": "MIT",
  "homepage": "https://guanriyue.github.io/decurl/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guanriyue/decurl.git",
    "directory": "packages/decurl"
  },
  "bugs": {
    "url": "https://github.com/guanriyue/decurl/issues"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./provided": {
        "types": "./dist/provided.d.ts",
        "import": "./dist/provided.js"
      },
      "./codec": {
        "types": "./dist/codec/index.d.ts",
        "import": "./dist/codec.js"
      },
      "./decode": {
        "types": "./dist/decode/index.d.ts",
        "import": "./dist/decode.js"
      },
      "./pagination": {
        "types": "./dist/pagination/index.d.ts",
        "import": "./dist/pagination.js"
      },
      "./routeSpec": {
        "types": "./dist/routeSpec/index.d.ts",
        "import": "./dist/routeSpec.js"
      }
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.17.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-router": "^7.0.0"
  }
}
