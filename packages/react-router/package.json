{
  "name": "@decurl/react-router",
  "version": "0.0.0",
  "description": "",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./configured": {
      "types": "./src/configured.tsx",
      "default": "./src/configured.tsx"
    },
    "./codec": {
      "types": "./src/codec.ts",
      "default": "./src/codec.ts"
    },
    "./decode": {
      "types": "./src/decode.ts",
      "default": "./src/decode.ts"
    },
    "./pagination": {
      "types": "./src/pagination/index.ts",
      "default": "./src/pagination/index.ts"
    },
    "./routeSpec": {
      "types": "./src/routeSpec/index.ts",
      "default": "./src/routeSpec/index.ts"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest run --pool=threads --maxWorkers=1 --no-file-parallelism"
  },
  "keywords": [],
  "author": "wangyuze0319@outlook.com",
  "license": "MIT",
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./configured": {
        "types": "./dist/configured.d.ts",
        "default": "./dist/configured.js"
      },
      "./codec": {
        "types": "./dist/codec.d.ts",
        "default": "./dist/codec.js"
      },
      "./decode": {
        "types": "./dist/decode.d.ts",
        "default": "./dist/decode.js"
      },
      "./pagination": {
        "types": "./dist/pagination/index.d.ts",
        "default": "./dist/pagination.js"
      },
      "./routeSpec": {
        "types": "./dist/routeSpec/index.d.ts",
        "default": "./dist/routeSpec.js"
      }
    }
  },
  "dependencies": {
    "@decurl/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.17.0"
