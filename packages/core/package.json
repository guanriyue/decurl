{
  "name": "@decurl/core",
  "version": "0.0.0",
  "description": "Internal codec and decode primitives for Decurl URL Search Params packages.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "author": {
    "name": "guanriyue",
    "url": "https://github.com/guanriyue"
  },
  "keywords": [
    "decurl",
    "internal",
    "url",
    "urlsearchparams",
    "search-params",
    "codec",
    "decode",
    "typescript"
  ],
  "homepage": "https://github.com/guanriyue/decurl/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guanriyue/decurl.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/guanriyue/decurl/issues"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.spec.ts"
  ],
  "exports": {
    "./decode": {
      "types": "./src/decode/index.ts",
      "import": "./src/decode/index.ts"
    },
    "./codec": {
      "types": "./src/codec/index.ts",
      "import": "./src/codec/index.ts"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "biome check ."
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./decode": {
        "types": "./dist/decode/index.d.ts",
        "import": "./dist/decode/index.js"
      },
      "./codec": {
        "types": "./dist/codec/index.d.ts",
        "import": "./dist/codec/index.js"
      }
    }
  }
}
